{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "auto-format",
            "type": "command",
            "command": "npm run format >&2",
            "description": "Automatically runs npm run format after file changes"
          }
        ]
      }
    ]
  }
}
